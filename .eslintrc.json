{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 13,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "off",
    "no-empty": "off",
    "no-empty-pattern": "off",
    "no-async-promise-executor": "off",
    "no-case-declarations": "off",
    "no-useless-escape": "off"
  }
}
